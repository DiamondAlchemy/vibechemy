{
  "name": "vibechemy",
  "version": "1.0.0",
  "description": "Vibechemy — terminal orchestration core",
  "license": "MIT",
  "author": "The Vibechemy Authors",
  "repository": {
    "type": "git",
    "url": "https://github.com/DiamondAlchemy/vibechemy.git"
  },
  "homepage": "https://github.com/DiamondAlchemy/vibechemy#readme",
  "bugs": {
    "url": "https://github.com/DiamondAlchemy/vibechemy/issues"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:mobile": "vite --config vite.mobile.config.ts",
    "build:mobile": "vite build --config vite.mobile.config.ts",
    "build": "npm run typecheck && electron-vite build",
    "fix:ptyhelper": "find node_modules/node-pty -name spawn-helper -type f -exec chmod +x {} + 2>/dev/null || true",
    "postinstall": "electron-builder install-app-deps && npm run fix:ptyhelper",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3,node-pty && npm run fix:ptyhelper",
    "rebuild:node": "npm rebuild better-sqlite3 node-pty && npm run fix:ptyhelper",
    "predev": "npm run rebuild:electron",
    "prestart": "npm run rebuild:electron",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:unpack": "npm run rebuild:electron && npm run build && electron-builder --dir",
    "build:mac": "npm run rebuild:electron && npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "node-pty": "^1.1.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.8"
  },
  "productName": "Vibechemy"
}
